    "var_08103f8a44ad": {
      "type": "variant",
      "label": "Mehfil Landing Page",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 1540,
        "y": 0,
        "w": 1440,
        "h": 800
      },
      "generation": {
        "prompt": "",
        "config": {}
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Manrope:wght@400;500;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --mehfil-cream: #FAF5EC;\n    --mehfil-royal: #921E2F;\n    --mehfil-gold: #DDB85C;\n    --mehfil-deep: #5C0E1B;\n    --mehfil-ink: #1A1106;\n    --font-royal: 'Cinzel', serif;\n    --font-editorial: 'Cormorant Garamond', serif;\n    --font-body: 'Manrope', sans-serif;\n  }\n\n  .mehfil-paper {\n    background: \n      radial-gradient(circle at 10% 10%, rgba(221, 184, 92, 0.08), transparent 40%),\n      radial-gradient(circle at 90% 80%, rgba(146, 30, 47, 0.05), transparent 50%),\n      var(--mehfil-cream);\n  }\n\n  .font-royal { font-family: var(--font-royal); }\n  .font-editorial { font-family: var(--font-editorial); }\n  .font-body { font-family: var(--font-body); }\n\n  .mehfil-btn-royal {\n    background: linear-gradient(180deg, #A92133 0%, var(--mehfil-royal) 100%);\n    border: 1px solid rgba(221, 184, 92, 0.5);\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.1), 0 8px 20px -10px rgba(138,26,42,0.5);\n  }\n\n  .mehfil-btn-gold {\n    background: linear-gradient(180deg, #F3EBD8 0%, var(--mehfil-gold) 100%);\n    border: 1px solid rgba(138,106,27,0.4);\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.3), 0 8px 20px -10px rgba(221, 184, 92, 0.5);\n  }\n\n  .mehfil-divider {\n    display: flex;\n    align-items: center;\n    gap: 1.5rem;\n  }\n  .mehfil-divider::before, .mehfil-divider::after {\n    content: \"\";\n    flex: 1;\n    height: 1px;\n    background: linear-gradient(to right, transparent, var(--mehfil-gold), transparent);\n  }\n\n  .glass-card {\n    background: rgba(255, 255, 255, 0.7);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(255, 255, 255, 0.4);\n  }\n</style>\n\n<div class=\"mehfil-paper min-h-screen font-body text-[var(--mehfil-ink)] selection:bg-[var(--mehfil-gold)] selection:text-[var(--mehfil-ink)]\" data-kid=\"1\">\n  \n  \n  <nav class=\"fixed top-0 w-full z-50 border-b border-[var(--mehfil-gold)]/20 bg-[var(--mehfil-cream)]/80 backdrop-blur-md\" data-kid=\"2\">\n    <div class=\"max-w-7xl mx-auto px-6 h-20 flex items-center justify-between\" data-kid=\"3\">\n      <div class=\"flex items-center gap-2\" data-kid=\"4\">\n        <div class=\"w-10 h-10 bg-[var(--mehfil-royal)] flex items-center justify-center rounded-sm rotate-45 border border-[var(--mehfil-gold)]\" data-kid=\"5\">\n          <span class=\"font-royal text-[var(--mehfil-gold)] -rotate-45 text-xl font-bold\" data-kid=\"6\">M</span>\n        </div>\n        <span class=\"font-royal text-2xl tracking-widest text-[var(--mehfil-royal)] font-bold\" data-kid=\"7\">MEHFIL</span>\n      </div>\n      \n      <div class=\"hidden md:flex items-center gap-10 font-royal text-sm tracking-widest uppercase\" data-kid=\"8\">\n        <a href=\"#\" class=\"hover:text-[var(--mehfil-royal)] transition-colors\" data-kid=\"9\">Experience</a>\n        <a href=\"#\" class=\"hover:text-[var(--mehfil-royal)] transition-colors\" data-kid=\"10\">The Menu</a>\n        <a href=\"#\" class=\"hover:text-[var(--mehfil-royal)] transition-colors\" data-kid=\"11\">Our Story</a>\n        <a href=\"#\" class=\"hover:text-[var(--mehfil-royal)] transition-colors\" data-kid=\"12\">Pricing</a>\n      </div>\n\n      <button class=\"mehfil-btn-royal px-8 py-3 rounded-xs font-royal text-xs tracking-[0.2em] uppercase text-[var(--mehfil-cream)] hover:brightness-110 transition-all\" data-kid=\"13\">\n        Book a Table\n      </button>\n    </div>\n  </nav>\n\n  \n  <section class=\"relative pt-40 pb-20 px-6 overflow-hidden\" data-kid=\"14\">\n    <div class=\"max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center\" data-kid=\"15\">\n      <div class=\"relative z-10\" data-kid=\"16\">\n        <div class=\"flex items-center gap-3 text-[var(--mehfil-gold)] mb-6\" data-kid=\"17\">\n          <i class=\"ti ti-vector-spline text-xl\" data-kid=\"18\"></i>\n          <span class=\"font-royal text-xs tracking-[0.4em] uppercase\" data-kid=\"19\">Premium Dining SaaS</span>\n        </div>\n        <h1 class=\"font-royal text-6xl md:text-8xl leading-tight text-[var(--mehfil-royal)] mb-8\" data-kid=\"20\">\n          The Heritage of <br data-kid=\"21\"> \n          <span class=\"italic font-editorial font-normal\" data-kid=\"22\">Hospitality</span>\n        </h1>\n        <p class=\"font-editorial text-2xl md:text-3xl text-[var(--mehfil-ink)]/70 mb-10 leading-relaxed max-w-xl\" data-kid=\"23\">\n          Elevating restaurant operations with a touch of royal Hyderabadi grace and state-of-the-art AI intelligence.\n        </p>\n        <div class=\"flex flex-col sm:flex-row gap-4\" data-kid=\"24\">\n          <button class=\"mehfil-btn-royal px-10 py-5 rounded-xs font-royal text-sm tracking-[0.2em] uppercase text-[var(--mehfil-cream)] hover:shadow-xl hover:-translate-y-0.5 transition-all\" data-kid=\"25\">\n            Get Started\n          </button>\n          <button class=\"px-10 py-5 rounded-xs font-royal text-sm tracking-[0.2em] uppercase text-[var(--mehfil-royal)] border border-[var(--mehfil-royal)] hover:bg-[var(--mehfil-royal)]/5 transition-all\" data-kid=\"26\">\n            View Live Demo\n          </button>\n        </div>\n      </div>\n\n      <div class=\"relative\" data-kid=\"27\">\n        <div class=\"absolute -inset-10 border border-[var(--mehfil-gold)]/30 rounded-full animate-[spin_20s_linear_infinite]\" data-kid=\"28\"></div>\n        <div class=\"relative aspect-[4/5] rounded-xs overflow-hidden border-4 border-[var(--mehfil-gold)] shadow-2xl\" data-kid=\"29\">\n          <img src=\"https://images.pexels.com/photos/5371552/pexels-photo-5371552.jpeg?auto=format&w=800&q=80&fit=crop\" alt=\"Royal Dining Experience\" class=\"w-full h-full object-cover grayscale-[0.2] hover:grayscale-0 transition-all duration-1000\" decoding=\"async\" loading=\"lazy\" data-kid=\"30\">\n          <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--mehfil-deep)]/40 to-transparent\" data-kid=\"31\"></div>\n        </div>\n        \n        \n        <div class=\"absolute -bottom-8 -left-8 glass-card p-6 rounded-xs shadow-xl border border-[var(--mehfil-gold)]/30 max-w-[200px]\" data-kid=\"32\">\n          <p class=\"font-royal text-3xl text-[var(--mehfil-royal)] mb-1\" data-kid=\"33\">98%</p>\n          <p class=\"text-[10px] uppercase tracking-widest text-[var(--mehfil-ink)]/60\" data-kid=\"34\">Guest Satisfaction Rating</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <div class=\"max-w-4xl mx-auto py-12\" data-kid=\"35\">\n    <div class=\"mehfil-divider\" data-kid=\"36\">\n      <i class=\"ti ti-grid-goldenratio text-[var(--mehfil-gold)] text-2xl\" data-kid=\"37\"></i>\n    </div>\n  </div>\n\n  \n  <section class=\"py-24 px-6 bg-white/40\" data-kid=\"38\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"39\">\n      <div class=\"text-center mb-20\" data-kid=\"40\">\n        <h2 class=\"font-royal text-4xl md:text-5xl text-[var(--mehfil-royal)] mb-6\" data-kid=\"41\">Transcending Complexity</h2>\n        <p class=\"font-editorial text-2xl text-[var(--mehfil-ink)]/60 max-w-2xl mx-auto\" data-kid=\"42\">Why modern restaurants choose the Mehfil touch over generic solutions.</p>\n      </div>\n\n      <div class=\"grid md:grid-cols-3 gap-8\" data-kid=\"43\">\n        \n        <div class=\"glass-card p-10 rounded-xs border-b-4 border-b-[var(--mehfil-royal)] hover:-translate-y-2 transition-all duration-500\" data-kid=\"44\">\n          <i class=\"ti ti-robot text-4xl text-[var(--mehfil-gold)] mb-6 block\" data-kid=\"45\"></i>\n          <h3 class=\"font-royal text-xl mb-4 text-[var(--mehfil-royal)]\" data-kid=\"46\">AI Royal Waiter</h3>\n          <p class=\"font-editorial text-lg text-[var(--mehfil-ink)]/80 leading-relaxed\" data-kid=\"47\">\n            Not just a bot, but a digital concierge trained in the art of Hyderabadi hospitality and suggestive selling.\n          </p>\n        </div>\n\n        \n        <div class=\"glass-card p-10 rounded-xs border-b-4 border-b-[var(--mehfil-gold)] hover:-translate-y-2 transition-all duration-500\" data-kid=\"48\">\n          <i class=\"ti ti-template-filled text-4xl text-[var(--mehfil-royal)] mb-6 block\" data-kid=\"49\"></i>\n          <h3 class=\"font-royal text-xl mb-4 text-[var(--mehfil-royal)]\" data-kid=\"50\">Editorial Menus</h3>\n          <p class=\"font-editorial text-lg text-[var(--mehfil-ink)]/80 leading-relaxed\" data-kid=\"51\">\n            Beautifully crafted digital menus that feel like high-end restaurant zines, driving 30% higher average order value.\n          </p>\n        </div>\n\n        \n        <div class=\"glass-card p-10 rounded-xs border-b-4 border-b-[var(--mehfil-royal)] hover:-translate-y-2 transition-all duration-500\" data-kid=\"52\">\n          <i class=\"ti ti-shield-checkered text-4xl text-[var(--mehfil-gold)] mb-6 block\" data-kid=\"53\"></i>\n          <h3 class=\"font-royal text-xl mb-4 text-[var(--mehfil-royal)]\" data-kid=\"54\">Frictionless Flow</h3>\n          <p class=\"font-editorial text-lg text-[var(--mehfil-ink)]/80 leading-relaxed\" data-kid=\"55\">\n            Zero app downloads. Zero account creation. Just a seamless journey from QR scan to the first bite.\n          </p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-6 overflow-hidden\" data-kid=\"56\">\n    <div class=\"max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-20\" data-kid=\"57\">\n      <div class=\"lg:w-1/2 order-2 lg:order-1 relative\" data-kid=\"58\">\n        <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] bg-[var(--mehfil-gold)]/5 rounded-full blur-3xl\" data-kid=\"59\"></div>\n        <div class=\"relative glass-card p-4 rounded-3xl shadow-2xl border border-[var(--mehfil-gold)]/30 max-w-[400px] mx-auto\" data-kid=\"60\">\n          <div class=\"bg-[var(--mehfil-deep)] rounded-2xl p-6 text-[var(--mehfil-cream)]\" data-kid=\"61\">\n            <div class=\"flex items-center gap-3 mb-8\" data-kid=\"62\">\n              <div class=\"w-10 h-10 rounded-full bg-[var(--mehfil-gold)]/20 flex items-center justify-center border border-[var(--mehfil-gold)]/40\" data-kid=\"63\">\n                <i class=\"ti ti-robot text-[var(--mehfil-gold)]\" data-kid=\"64\"></i>\n              </div>\n              <div data-kid=\"65\">\n                <p class=\"text-[10px] uppercase tracking-widest opacity-60\" data-kid=\"66\">AI Concierge</p>\n                <p class=\"font-royal text-xs\" data-kid=\"67\">Mehfil Assistant</p>\n              </div>\n            </div>\n            \n            <div class=\"space-y-4 mb-8\" data-kid=\"68\">\n              <div class=\"bg-white/5 p-4 rounded-xl rounded-tl-none border border-white/10\" data-kid=\"69\">\n                <p class=\"font-editorial text-lg\" data-kid=\"70\">\"The Nizami Biryani today is exceptional. Would you like to pair it with our signature Mirchi ka Salan?\"</p>\n              </div>\n              <div class=\"bg-[var(--mehfil-gold)] p-4 rounded-xl rounded-tr-none text-[var(--mehfil-ink)] ml-8\" data-kid=\"71\">\n                <p class=\"font-body text-sm font-medium\" data-kid=\"72\">Yes, please add that to my order.</p>\n              </div>\n            </div>\n\n            <div class=\"flex items-center justify-between border-t border-white/10 pt-4\" data-kid=\"73\">\n              <div class=\"flex items-center gap-2\" data-kid=\"74\">\n                <div class=\"w-2 h-2 rounded-full bg-green-500 animate-pulse\" data-kid=\"75\"></div>\n                <span class=\"text-[10px] uppercase tracking-widest opacity-60\" data-kid=\"76\">Thinking...</span>\n              </div>\n              <i class=\"ti ti-photo-bitcoin text-[var(--mehfil-gold)]\" data-kid=\"77\"></i>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"lg:w-1/2 order-1 lg:order-2\" data-kid=\"78\">\n        <h2 class=\"font-royal text-5xl md:text-6xl text-[var(--mehfil-royal)] mb-8 leading-tight\" data-kid=\"79\">Intelligence Wrapped <br data-kid=\"80\"> in <span class=\"italic font-editorial font-normal\" data-kid=\"81\">Elegance</span></h2>\n        <p class=\"font-editorial text-2xl text-[var(--mehfil-ink)]/70 mb-10 leading-relaxed\" data-kid=\"82\">\n          Our AI doesn't just take orders; it understands the soul of your menu. It engages guests in a natural, sophisticated dialogue that reflects your brand's prestige.\n        </p>\n        <ul class=\"space-y-6\" data-kid=\"83\">\n          <li class=\"flex items-start gap-4\" data-kid=\"84\">\n            <div class=\"mt-1 w-6 h-6 rounded-full bg-[var(--mehfil-gold)]/10 flex items-center justify-center border border-[var(--mehfil-gold)]/30\" data-kid=\"85\">\n              <i class=\"ti ti-shield-dollar text-[var(--mehfil-gold)] text-xs\" data-kid=\"86\"></i>\n            </div>\n            <div data-kid=\"87\">\n              <p class=\"font-royal text-sm text-[var(--mehfil-royal)] tracking-widest uppercase\" data-kid=\"88\">Upselling with Grace</p>\n              <p class=\"font-editorial text-lg text-[var(--mehfil-ink)]/60\" data-kid=\"89\">Increases revenue without being intrusive.</p>\n            </div>\n          </li>\n          <li class=\"flex items-start gap-4\" data-kid=\"90\">\n            <div class=\"mt-1 w-6 h-6 rounded-full bg-[var(--mehfil-gold)]/10 flex items-center justify-center border border-[var(--mehfil-gold)]/30\" data-kid=\"91\">\n              <i class=\"ti ti-vector-spline text-[var(--mehfil-gold)] text-xs\" data-kid=\"92\"></i>\n            </div>\n            <div data-kid=\"93\">\n              <p class=\"font-royal text-sm text-[var(--mehfil-royal)] tracking-widest uppercase\" data-kid=\"94\">Multi-Lingual Mastery</p>\n              <p class=\"font-editorial text-lg text-[var(--mehfil-ink)]/60\" data-kid=\"95\">Fluent in over 40 languages, including local dialects.</p>\n            </div>\n          </li>\n        </ul>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-24 px-6\" data-kid=\"96\">\n    <div class=\"max-w-5xl mx-auto bg-[var(--mehfil-deep)] rounded-xs overflow-hidden relative shadow-2xl border border-[var(--mehfil-gold)]/30\" data-kid=\"97\">\n      <div class=\"absolute inset-0 bg-[url('https://images.pexels.com/photos/28674660/pexels-photo-28674660.jpeg?auto=format&w=1200&q=40&fit=crop')] bg-cover bg-center opacity-20\" data-kid=\"98\"></div>\n      <div class=\"relative z-10 py-20 px-10 text-center\" data-kid=\"99\">\n        <h2 class=\"font-royal text-4xl md:text-5xl text-[var(--mehfil-gold)] mb-8\" data-kid=\"100\">Ready for the Royal Upgrade?</h2>\n        <p class=\"font-editorial text-2xl text-[var(--mehfil-cream)]/70 mb-12 max-w-2xl mx-auto\" data-kid=\"101\">Join the elite restaurants redefining hospitality for the digital age.</p>\n        <div class=\"flex flex-col sm:flex-row gap-6 justify-center\" data-kid=\"102\">\n          <button class=\"mehfil-btn-gold px-12 py-5 rounded-xs font-royal text-sm tracking-[0.2em] uppercase text-[var(--mehfil-ink)] font-bold hover:scale-105 transition-all\" data-kid=\"103\">\n            Start Your Trial\n          </button>\n          <button class=\"px-12 py-5 rounded-xs font-royal text-sm tracking-[0.2em] uppercase text-[var(--mehfil-cream)] border border-[var(--mehfil-gold)]/40 hover:bg-white/5 transition-all\" data-kid=\"104\">\n            Schedule a Demo\n          </button>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"bg-[var(--mehfil-ink)] text-[var(--mehfil-cream)] pt-24 pb-12 px-6 border-t border-[var(--mehfil-gold)]/20\" data-kid=\"105\">\n    <div class=\"max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-16 mb-20\" data-kid=\"106\">\n      <div class=\"col-span-1 md:col-span-1\" data-kid=\"107\">\n        <div class=\"flex items-center gap-2 mb-8\" data-kid=\"108\">\n          <div class=\"w-8 h-8 bg-[var(--mehfil-gold)] flex items-center justify-center rounded-sm rotate-45\" data-kid=\"109\">\n            <span class=\"font-royal text-[var(--mehfil-ink)] -rotate-45 text-sm font-bold\" data-kid=\"110\">M</span>\n          </div>\n          <span class=\"font-royal text-xl tracking-widest text-[var(--mehfil-gold)] font-bold\" data-kid=\"111\">MEHFIL</span>\n        </div>\n        <p class=\"font-editorial text-lg text-[var(--mehfil-cream)]/50 leading-relaxed\" data-kid=\"112\">\n          Crafting the future of restaurant intelligence with the timeless elegance of heritage hospitality.\n        </p>\n      </div>\n\n      <div data-kid=\"113\">\n        <h4 class=\"font-royal text-xs tracking-[0.3em] uppercase text-[var(--mehfil-gold)] mb-8\" data-kid=\"114\">Product</h4>\n        <ul class=\"space-y-4 font-editorial text-lg text-[var(--mehfil-cream)]/60\" data-kid=\"115\">\n          <li data-kid=\"116\"><a href=\"#\" class=\"hover:text-[var(--mehfil-gold)] transition-colors\" data-kid=\"117\">AI Waiter</a></li>\n          <li data-kid=\"118\"><a href=\"#\" class=\"hover:text-[var(--mehfil-gold)] transition-colors\" data-kid=\"119\">Digital Menus</a></li>\n          <li data-kid=\"120\"><a href=\"#\" class=\"hover:text-[var(--mehfil-gold)] transition-colors\" data-kid=\"121\">Admin Dashboard</a></li>\n          <li data-kid=\"122\"><a href=\"#\" class=\"hover:text-[var(--mehfil-gold)] transition-colors\" data-kid=\"123\">Kitchen Display</a></li>\n        </ul>\n      </div>\n\n      <div data-kid=\"124\">\n        <h4 class=\"font-royal text-xs tracking-[0.3em] uppercase text-[var(--mehfil-gold)] mb-8\" data-kid=\"125\">Company</h4>\n        <ul class=\"space-y-4 font-editorial text-lg text-[var(--mehfil-cream)]/60\" data-kid=\"126\">\n          <li data-kid=\"127\"><a href=\"#\" class=\"hover:text-[var(--mehfil-gold)] transition-colors\" data-kid=\"128\">About Us</a></li>\n          <li data-kid=\"129\"><a href=\"#\" class=\"hover:text-[var(--mehfil-gold)] transition-colors\" data-kid=\"130\">Careers</a></li>\n          <li data-kid=\"131\"><a href=\"#\" class=\"hover:text-[var(--mehfil-gold)] transition-colors\" data-kid=\"132\">The Journal</a></li>\n          <li data-kid=\"133\"><a href=\"#\" class=\"hover:text-[var(--mehfil-gold)] transition-colors\" data-kid=\"134\">Partners</a></li>\n        </ul>\n      </div>\n\n      <div data-kid=\"135\">\n        <h4 class=\"font-royal text-xs tracking-[0.3em] uppercase text-[var(--mehfil-gold)] mb-8\" data-kid=\"136\">Newsletter</h4>\n        <p class=\"font-editorial text-sm text-[var(--mehfil-cream)]/50 mb-6 uppercase tracking-wider\" data-kid=\"137\">Updates from the dining room.</p>\n        <div class=\"flex border-b border-[var(--mehfil-gold)]/40 pb-2\" data-kid=\"138\">\n          <input type=\"email\" placeholder=\"Your Email\" class=\"bg-transparent border-none outline-none flex-1 font-editorial text-lg text-[var(--mehfil-cream)] placeholder:text-[var(--mehfil-cream)]/30\" data-kid=\"139\">\n          <button class=\"text-[var(--mehfil-gold)] uppercase font-royal text-[10px] tracking-widest\" data-kid=\"140\">Subscribe</button>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"max-w-7xl mx-auto pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6\" data-kid=\"141\">\n      <p class=\"font-royal text-[10px] tracking-[0.3em] uppercase opacity-40\" data-kid=\"142\">© 2024 Mehfil AI Systems. All rights reserved.</p>\n      <div class=\"flex gap-8 font-royal text-[10px] tracking-[0.3em] uppercase opacity-40\" data-kid=\"143\">\n        <a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"144\">Privacy</a>\n        <a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"145\">Terms</a>\n        <a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"146\">Security</a>\n      </div>\n    </div>\n  </footer>\n\n</div>",
