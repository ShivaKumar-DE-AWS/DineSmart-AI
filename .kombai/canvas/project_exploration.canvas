      "html": "<style data-kid=\"0\">\n  @import url('https://api.fontshare.com/v2/css?f[]=cabinet-grotesk@800,500,700,400,300&display=swap');\n  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  .font-heading { font-family: 'Cabinet Grotesk', sans-serif; }\n  .font-body { font-family: 'Manrope', sans-serif; }\n  \n  :root {\n    --color-background: #F6F4F0;\n    --color-surface: #FFFFFF;\n    --color-primary: #C84B31;\n    --color-primary-hover: #A83C25;\n    --color-text-primary: #1A1A1A;\n    --color-text-secondary: #5C5C5C;\n    --color-border: #E2DFD8;\n    --color-warn: #FF9F0A;\n  }\n</style>\n\n<div class=\"min-h-screen bg-[var(--color-background)] font-body text-[var(--color-text-primary)] p-4 md:p-8\" data-kid=\"1\">\n  \n  <div class=\"flex items-end justify-between mb-8\" data-kid=\"2\">\n    <div data-kid=\"3\">\n      <p class=\"uppercase tracking-[0.3em] text-[10px] text-[var(--color-text-secondary)] mb-1 font-semibold\" data-kid=\"4\">Overview</p>\n      <h1 class=\"font-heading text-3xl tracking-tight font-bold\" data-testid=\"admin-dashboard-title\" data-kid=\"5\">Restaurant pulse</h1>\n    </div>\n    <div class=\"text-[10px] text-[var(--color-text-secondary)] font-medium\" data-kid=\"6\">Auto-refreshes every 10s</div>\n  </div>\n\n  \n  <div class=\"grid grid-cols-2 md:grid-cols-4 gap-4 mb-8\" data-kid=\"7\">\n    \n    <div data-testid=\"kpi-revenue\" class=\"border border-[var(--color-border)] bg-[var(--color-surface)] rounded-2xl p-5 hover:border-[var(--color-primary)]/30 transition-colors\" data-kid=\"8\">\n      <div class=\"flex items-center justify-between text-[var(--color-text-secondary)] text-[10px] uppercase tracking-widest font-bold\" data-kid=\"9\">\n        <span data-kid=\"10\">Revenue today</span>\n        <i class=\"ti ti-trending-up text-lg text-[var(--color-primary)]\" data-kid=\"11\"></i>\n      </div>\n      <div class=\"font-heading text-2xl mt-3 tracking-tight font-bold\" data-kid=\"12\">$4,285.50</div>\n    </div>\n    \n    \n    <div data-testid=\"kpi-orders\" class=\"border border-[var(--color-border)] bg-[var(--color-surface)] rounded-2xl p-5 hover:border-[var(--color-primary)]/30 transition-colors\" data-kid=\"13\">\n      <div class=\"flex items-center justify-between text-[var(--color-text-secondary)] text-[10px] uppercase tracking-widest font-bold\" data-kid=\"14\">\n        <span data-kid=\"15\">Orders today</span>\n        <i class=\"ti ti-shopping-bag text-lg text-[var(--color-primary)]\" data-kid=\"16\"></i>\n      </div>\n      <div class=\"font-heading text-2xl mt-3 tracking-tight font-bold\" data-kid=\"17\">142</div>\n    </div>\n    \n    \n    <div data-testid=\"kpi-ai\" class=\"border border-[var(--color-border)] bg-[var(--color-surface)] rounded-2xl p-5 hover:border-[var(--color-primary)]/30 transition-colors\" data-kid=\"18\">\n      <div class=\"flex items-center justify-between text-[var(--color-text-secondary)] text-[10px] uppercase tracking-widest font-bold\" data-kid=\"19\">\n        <span data-kid=\"20\">AI Influence</span>\n        <i class=\"ti ti-receipt text-lg text-[var(--color-primary)]\" data-kid=\"21\"></i>\n      </div>\n      <div class=\"font-heading text-2xl mt-3 tracking-tight font-bold\" data-kid=\"22\">68%</div>\n    </div>\n    \n    \n    <div data-testid=\"kpi-low-stock\" class=\"border border-[var(--color-border)] bg-[var(--color-surface)] rounded-2xl p-5 hover:border-[var(--color-primary)]/30 transition-colors\" data-kid=\"23\">\n      <div class=\"flex items-center justify-between text-[var(--color-text-secondary)] text-[10px] uppercase tracking-widest font-bold\" data-kid=\"24\">\n        <span data-kid=\"25\">Low stock items</span>\n        <i class=\"ti ti-alert-triangle text-lg text-[var(--color-primary)]\" data-kid=\"26\"></i>\n      </div>\n      <div class=\"font-heading text-2xl mt-3 tracking-tight font-bold\" data-kid=\"27\">12</div>\n    </div>\n  </div>\n\n  \n  <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-6\" data-kid=\"28\">\n    \n    <div class=\"lg:col-span-2 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-2xl p-6\" data-kid=\"29\">\n      <div class=\"flex items-center justify-between mb-6\" data-kid=\"30\">\n        <h2 class=\"font-heading text-lg font-bold\" data-kid=\"31\">Revenue · last 7 days</h2>\n        <div class=\"flex items-center gap-2\" data-kid=\"32\">\n          <span class=\"w-3 h-3 rounded-full bg-[var(--color-primary)]\" data-kid=\"33\"></span>\n          <span class=\"text-xs text-[var(--color-text-secondary)]\" data-kid=\"34\">Gross Revenue</span>\n        </div>\n      </div>\n      <div class=\"h-64 w-full\" data-testid=\"revenue-chart\" data-kid=\"35\">\n        <canvas id=\"revenueChart\" data-kid=\"36\"></canvas>\n      </div>\n    </div>\n\n    \n    <div class=\"bg-[var(--color-surface)] border border-[var(--color-border)] rounded-2xl p-6\" data-kid=\"37\">\n      <h2 class=\"font-heading text-lg font-bold mb-6\" data-kid=\"38\">Top items today</h2>\n      <ul class=\"space-y-4\" data-testid=\"top-items-list\" data-kid=\"39\">\n        <li class=\"flex items-center justify-between group\" data-kid=\"40\">\n          <div class=\"flex items-center gap-3\" data-kid=\"41\">\n            <span class=\"w-8 h-8 rounded-lg bg-[var(--color-background)] flex items-center justify-center text-xs font-bold text-[var(--color-primary)]\" data-kid=\"42\">01</span>\n            <span class=\"text-sm font-medium\" data-kid=\"43\">Hyderabadi Chicken Biryani</span>\n          </div>\n          <span class=\"font-mono text-sm text-[var(--color-primary)] bg-[var(--color-primary)]/5 px-2 py-1 rounded-md\" data-kid=\"44\">48×</span>\n        </li>\n        <li class=\"flex items-center justify-between group\" data-kid=\"45\">\n          <div class=\"flex items-center gap-3\" data-kid=\"46\">\n            <span class=\"w-8 h-8 rounded-lg bg-[var(--color-background)] flex items-center justify-center text-xs font-bold text-[var(--color-primary)]\" data-kid=\"47\">02</span>\n            <span class=\"text-sm font-medium\" data-kid=\"48\">Double Ka Meetha</span>\n          </div>\n          <span class=\"font-mono text-sm text-[var(--color-primary)] bg-[var(--color-primary)]/5 px-2 py-1 rounded-md\" data-kid=\"49\">32×</span>\n        </li>\n        <li class=\"flex items-center justify-between group\" data-kid=\"50\">\n          <div class=\"flex items-center gap-3\" data-kid=\"51\">\n            <span class=\"w-8 h-8 rounded-lg bg-[var(--color-background)] flex items-center justify-center text-xs font-bold text-[var(--color-primary)]\" data-kid=\"52\">03</span>\n            <span class=\"text-sm font-medium\" data-kid=\"53\">Mutton Haleem (Seasonal)</span>\n          </div>\n          <span class=\"font-mono text-sm text-[var(--color-primary)] bg-[var(--color-primary)]/5 px-2 py-1 rounded-md\" data-kid=\"54\">25×</span>\n        </li>\n        <li class=\"flex items-center justify-between group\" data-kid=\"55\">\n          <div class=\"flex items-center gap-3\" data-kid=\"56\">\n            <span class=\"w-8 h-8 rounded-lg bg-[var(--color-background)] flex items-center justify-center text-xs font-bold text-[var(--color-primary)]\" data-kid=\"57\">04</span>\n            <span class=\"text-sm font-medium\" data-kid=\"58\">Irani Chai</span>\n          </div>\n          <span class=\"font-mono text-sm text-[var(--color-primary)] bg-[var(--color-primary)]/5 px-2 py-1 rounded-md\" data-kid=\"59\">19×</span>\n        </li>\n      </ul>\n      <button class=\"w-full mt-8 py-3 rounded-xl border border-[var(--color-border)] text-xs font-bold uppercase tracking-widest hover:bg-[var(--color-background)] transition-colors\" data-kid=\"60\">\n        View all analytics\n      </button>\n    </div>\n  </div>\n\n  \n  <div class=\"mt-8 bg-[var(--color-warn)]/5 border border-[var(--color-warn)]/20 rounded-2xl p-6\" data-testid=\"low-stock-alert\" data-kid=\"61\">\n    <div class=\"flex items-center gap-3 mb-6\" data-kid=\"62\">\n      <div class=\"w-10 h-10 rounded-xl bg-[var(--color-warn)]/10 flex items-center justify-center\" data-kid=\"63\">\n        <i class=\"ti ti-alert-triangle text-xl text-[var(--color-warn)]\" data-kid=\"64\"></i>\n      </div>\n      <div data-kid=\"65\">\n        <h3 class=\"font-heading text-base font-bold text-[var(--color-text-primary)]\" data-kid=\"66\">Inventory attention required</h3>\n        <p class=\"text-xs text-[var(--color-text-secondary)]\" data-kid=\"67\">These items have fallen below their reorder levels</p>\n      </div>\n    </div>\n    <div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 text-sm\" data-kid=\"68\">\n      <div class=\"bg-[var(--color-surface)] rounded-xl p-4 border border-[var(--color-border)] hover:border-[var(--color-warn)]/40 transition-colors\" data-kid=\"69\">\n        <div class=\"font-bold mb-1\" data-kid=\"70\">Basmati Rice (Extra Long)</div>\n        <div class=\"text-[var(--color-text-secondary)] text-xs\" data-kid=\"71\">15.0 kg · <span class=\"text-[var(--color-warn)] font-bold\" data-kid=\"72\">reorder at 25.0 kg</span></div>\n      </div>\n      <div class=\"bg-[var(--color-surface)] rounded-xl p-4 border border-[var(--color-border)] hover:border-[var(--color-warn)]/40 transition-colors\" data-kid=\"73\">\n        <div class=\"font-bold mb-1\" data-kid=\"74\">Saffron (Premium Grade)</div>\n        <div class=\"text-[var(--color-text-secondary)] text-xs\" data-kid=\"75\">45.0 g · <span class=\"text-[var(--color-warn)] font-bold\" data-kid=\"76\">reorder at 100.0 g</span></div>\n      </div>\n      <div class=\"bg-[var(--color-surface)] rounded-xl p-4 border border-[var(--color-border)] hover:border-[var(--color-warn)]/40 transition-colors\" data-kid=\"77\">\n        <div class=\"font-bold mb-1\" data-kid=\"78\">Ghee (Pure Buffalo)</div>\n        <div class=\"text-[var(--color-text-secondary)] text-xs\" data-kid=\"79\">8.0 L · <span class=\"text-[var(--color-warn)] font-bold\" data-kid=\"80\">reorder at 20.0 L</span></div>\n      </div>\n      <div class=\"bg-[var(--color-surface)] rounded-xl p-4 border border-[var(--color-border)] hover:border-[var(--color-warn)]/40 transition-colors\" data-kid=\"81\">\n        <div class=\"font-bold mb-1\" data-kid=\"82\">Whole Cardamom</div>\n        <div class=\"text-[var(--color-text-secondary)] text-xs\" data-kid=\"83\">1.2 kg · <span class=\"text-[var(--color-warn)] font-bold\" data-kid=\"84\">reorder at 3.0 kg</span></div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"85\"></script>\n<script data-kid=\"86\">\n  window.onload = function() {\n    const ctx = document.getElementById('revenueChart').getContext('2d');\n    new Chart(ctx, {\n      type: 'line',\n      data: {\n        labels: ['Jun 20', 'Jun 21', 'Jun 22', 'Jun 23', 'Jun 24', 'Jun 25', 'Jun 26'],\n        datasets: [{\n          label: 'Revenue',\n          data: [3200, 4100, 3800, 5200, 4800, 4600, 4285],\n          borderColor: '#C84B31',\n          borderWidth: 3,\n          tension: 0.4,\n          pointBackgroundColor: '#C84B31',\n          pointRadius: 4,\n          pointHoverRadius: 6,\n          fill: true,\n          backgroundColor: function(context) {\n            const chart = context.chart;\n            const {ctx, chartArea} = chart;\n            if (!chartArea) return null;\n            const gradient = ctx.createLinearGradient(0, chartArea.top, 0, chartArea.bottom);\n            gradient.addColorStop(0, 'rgba(200, 75, 49, 0.1)');\n            gradient.addColorStop(1, 'rgba(200, 75, 49, 0)');\n            return gradient;\n          }\n        }]\n      },\n      options: {\n        responsive: true,\n        maintainAspectRatio: false,\n        plugins: {\n          legend: { display: false },\n          tooltip: {\n            backgroundColor: '#FFFFFF',\n            titleColor: '#1A1A1A',\n            bodyColor: '#5C5C5C',\n            borderColor: '#E2DFD8',\n            borderWidth: 1,\n            padding: 12,\n            cornerRadius: 12,\n            displayColors: false,\n            callbacks: {\n              label: (item) => '$' + item.formattedValue\n            }\n          }\n        },\n        scales: {\n          x: {\n            grid: { display: false },\n            ticks: {\n              color: '#5C5C5C',\n              font: { family: 'Manrope', size: 11 }\n            }\n          },\n          y: {\n            grid: { color: '#E2DFD8', borderDash: [3, 3] },\n            ticks: {\n              color: '#5C5C5C',\n              font: { family: 'Manrope', size: 11 },\n              callback: (value) => '$' + value\n            }\n          }\n        }\n      }\n    });\n  };\n</script>",
      "comments": [],
      "created": "2026-06-26T10:04:38.176903+00:00",
      "modified": "2026-06-26T10:04:59.075215+00:00",
